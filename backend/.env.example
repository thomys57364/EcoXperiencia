# ============================================
# DATABASE CONFIGURATION
# ============================================
# SUPABASE (gratis): Crea un proyecto en https://supabase.com
# Ve a: Project Settings > Database > Connection String > URI
# Reemplaza [YOUR-PASSWORD] con tu contraseña de base de datos
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ============================================
# APLICACIÓN
# ============================================
NODE_ENV="development"
PORT=3000

# ============================================
# JWT SEGURIDAD
# ============================================
# Generar secrets seguros: openssl rand -hex 32
JWT_SECRET="your-super-secret-jwt-key-here-min-32-chars"
JWT_EXPIRY="7d"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-here-min-32-chars"
JWT_REFRESH_EXPIRY="30d"

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Opciones: "sendgrid" o "resend"
EMAIL_PROVIDER="sendgrid"
EMAIL_FROM="noreply@ecoxperiencia.com"

# SendGrid
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Resend (alternativa)
# RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================
# STRIPE (PAGOS)
# ============================================
# Obtener en: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================
# IMÁGENES (Cloudinary o AWS S3)
# ============================================

# --- OPCIÓN 1: Cloudinary (Recomendado para desarrollo) ---
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# --- OPCIÓN 2: AWS S3 (Para producción) ---
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="xxxxxxxxxxxxxxxxxxxx"
# AWS_SECRET_ACCESS_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# AWS_S3_BUCKET="ecoxperiencia-images"
# AWS_S3_URL="https://ecoxperiencia-images.s3.amazonaws.com"

# ============================================
# GOOGLE SERVICES (Opcional)
# ============================================
# GOOGLE_MAPS_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# GOOGLE_OAUTH_CLIENT_ID="xxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com"
# GOOGLE_OAUTH_CLIENT_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ============================================
# REDIS (Caché y Rate Limiting)
# ============================================
# REDIS_HOST="localhost"
# REDIS_PORT="6379"
# REDIS_PASSWORD=""

# ============================================
# LOGGING
# ============================================
LOG_LEVEL="debug"
# LOG_FILE="./logs/app.log"

# ============================================
# CORS
# ============================================
# En Railway, pon la URL de tu sitio Netlify aquí
# Ejemplo: CORS_ORIGIN="https://ecoxperiencia.netlify.app,http://localhost:3001"
CORS_ORIGIN="http://localhost:3000,http://localhost:3001,http://localhost:5173"

# ============================================
# FRONTEND URL (para redirecciones)
# ============================================
FRONTEND_URL="http://localhost:5173"
ADMIN_URL="http://localhost:5174"
